+/** Cek magic bytes ZIP (PK\x03\x04) — .xlsx adalah container ZIP (OPC). */
+export function isXlsxMagicBytes(buffer: Buffer): boolean {
+  return (
+    buffer.length >= 4 &&
+    buffer[0] === 0x50 &&
+    buffer[1] === 0x4b &&
+    buffer[2] === 0x03 &&
+    buffer[3] === 0x04
+  );
+}
