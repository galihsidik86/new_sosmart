// Lentera — Prisma schema
// Konvensi:
//   * Setiap tabel multi-tenant punya `tenantId UUID NOT NULL`.
//   * Row-Level Security (RLS) di-enforce di Postgres lewat migrasi SQL terpisah
//     (lihat migrations/.../rls.sql). Aplikasi runtime pakai user non-superuser
//     (lentera_app); migrasi & seed pakai superuser (lentera).
//   * Semua nominal pakai Decimal(20, 2) — JANGAN pernah Float.
//   * Snake_case di DB, camelCase di Prisma client (lewat @map).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ===============================================================
// ENUMS
// ===============================================================

enum Role {
  OWNER
  ADMIN
  AKUNTAN
  KASIR
  AUDITOR
}

enum AccountKind {
  ASET
  LIABILITAS
  EKUITAS
  PENDAPATAN
  BEBAN_POKOK
  BEBAN
  PENDAPATAN_LAIN
  BEBAN_LAIN
}

enum NormalBalance {
  DEBIT
  KREDIT
}

enum KlasifikasiNeraca {
  ASET_LANCAR
  ASET_TETAP
  LIABILITAS_PENDEK
  LIABILITAS_PANJANG
}

enum BankReconciliationStatus {
  DRAFT
  SELESAI
}

enum ApprovalDocType {
  PENJUALAN
  PEMBELIAN
  KAS_BANK
  JURNAL
}

enum ApprovalStatus {
  MENUNGGU
  DISETUJUI
  DITOLAK
}

enum ApprovalActionType {
  SETUJU
  TOLAK
}

enum PpnSkema {
  EFEKTIF_11
  EFEKTIF_12
  KHUSUS
  BEBAS
  TIDAK_DIPUNGUT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  POST
  UNPOST
  LOGIN
  LOGOUT
}

/// Klasifikasi PPN per item — menentukan bagaimana item diperlakukan
/// di faktur penjualan/pembelian dan SPT Masa PPN.
enum KlasifikasiPpn {
  BKP // Barang Kena Pajak (kena PPN)
  JKP // Jasa Kena Pajak (kena PPN, biasanya juga PPh 23)
  NON_BKP // Tidak kena PPN
  BKP_STRATEGIS // BKP strategis (PPN 0% / dibebaskan, mis. sembako tertentu)
  BEBAS_PPN // PPN dibebaskan (kawasan berikat, ekspor, dll)
}

/// Tipe pelanggan — mempengaruhi termin & kebijakan harga.
enum TipeCustomer {
  DISTRIBUTOR
  RITEL
  KORPORAT
  KOPERASI
  PEMERINTAH
  LAINNYA
}

/// Status periode buku — gating untuk posting transaksi.
enum PeriodStatus {
  OPEN
  CLOSING // sedang proses tutup (jurnal penyesuaian)
  CLOSED
}

/// Status tahun buku.
enum FiscalYearStatus {
  OPEN
  CLOSED
}

/// Status jurnal — DRAFT belum mempengaruhi ledger; POSTED sudah; REVERSED
/// dibalik oleh jurnal lain (tidak boleh dihapus, jejak audit dipertahankan).
enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

/// Sumber jurnal — menentukan dari modul mana jurnal terbit.
/// Dipakai di buku besar & audit untuk telusur balik ke dokumen sumber.
enum JournalSource {
  MANUAL // input langsung oleh user
  PENJUALAN // dari faktur penjualan (Fase 4)
  RETUR_JUAL
  PEMBELIAN // dari tagihan pembelian (Fase 4)
  RETUR_BELI
  KAS_BANK // penerimaan/pengeluaran kas/bank
  PENYUSUTAN // auto-post bulanan aset tetap (Fase 6)
  PENYESUAIAN // jurnal penyesuaian (adjusting)
  TUTUP_BUKU // jurnal penutup periode/tahun
  PAJAK // posting otomatis dari modul pajak (Fase 7)
  SALDO_AWAL // dari prosedur saldo awal terintegrasi (Fase 9)
}

/// Status faktur penjualan/pembelian.
enum InvoiceStatus {
  DRAFT
  POSTED // sudah dijurnal & menjadi AR/AP
  PAID // sudah lunas (semua pelunasan diterima)
  PARTIAL // sudah ada pelunasan tapi belum lunas
  CANCELLED // dibatalkan (kalau POSTED → pembalik diterbitkan)
}

/// Termin pembayaran — TUNAI langsung clearing, KREDIT pakai termin hari.
enum TerminPembayaran {
  TUNAI
  KREDIT
}

/// Kode faktur pajak PMK 03/PJ/2022.
/// 010 = transaksi biasa (PPN dipungut)
/// 020 = penyerahan ke pemungut PPN (BUMN, K/L)
/// 030 = bendaharawan
/// 040 = DPP nilai lain (mis. emas perhiasan)
/// 050 = besaran tertentu (sewa kendaraan, dll)
/// 060 = penyerahan lain
/// 070 = PPN tidak dipungut (kawasan berikat/free trade)
/// 080 = PPN dibebaskan (BKP strategis, ekspor jasa)
/// 090 = penyerahan aktiva (Ps 16D)
enum KodeFakturPajak {
  K010
  K020
  K030
  K040
  K050
  K060
  K070
  K080
  K090
}

/// Jenis transaksi kas/bank.
enum CashBankType {
  RECEIPT // penerimaan kas/bank (debit kas/bank)
  PAYMENT // pengeluaran kas/bank (kredit kas/bank)
  TRANSFER // mutasi antar akun kas/bank internal
}

/// Metode pencatatan harga pokok persediaan.
/// FIFO: First-In First-Out (lot tertua keluar duluan).
/// AVERAGE: rata-rata berjalan (moving average).
/// Pilih per tenant, tidak boleh ganti setelah ada transaksi (UU PPh konsistensi).
enum CostMethod {
  FIFO
  AVERAGE
}

/// Status PTKP karyawan — menentukan PTKP tahunan & kategori TER bulanan.
///   TK = Tidak Kawin · K = Kawin · HB = Hidup Berpisah · angka = tanggungan (0..3).
enum PtkpStatus {
  TK_0
  TK_1
  TK_2
  TK_3
  K_0
  K_1
  K_2
  K_3
  HB_0
  HB_1
  HB_2
  HB_3
}

/// Kategori TER PMK 168/2023 (tarif efektif bulanan PPh 21):
///   A = TK_0
///   B = TK_1, K_0, TK_2
///   C = TK_3, K_1, K_2, K_3, HB_0..HB_3
enum PtkpKategori {
  A
  B
  C
}

enum JenisKaryawan {
  PEGAWAI_TETAP
  PEGAWAI_TIDAK_TETAP
  BUKAN_PEGAWAI
  PENERIMA_PENSIUN
}

enum BuktiPotongStatus {
  DRAFT
  TERBIT
  DIKIRIM_DJP
  DIBATALKAN
}

/// Jenis Pajak Penghasilan untuk e-Bupot Unifikasi (PER-24/PJ/2021 + Coretax).
enum JenisPph {
  PPH_21 // gaji karyawan
  PPH_22 // impor / pemungut tertentu
  PPH_23 // jasa, dividen, bunga, royalti
  PPH_25 // angsuran bulanan
  PPH_26 // WP luar negeri
  PPH_29 // kurang bayar tahunan
  PPH_4_AYAT_2 // final: sewa tanah/bangunan, jasa konstruksi
  PPH_15 // sektor tertentu (pelayaran, penerbangan, dll)
}

/// Status aset tetap.
enum AsetStatus {
  AKTIF // sedang dipakai, masih disusutkan
  DIJUAL // sudah dilepas via penjualan aset
  RUSAK // dihentikan karena rusak (write-off)
  PENSIUN // diafkir tapi belum dijual
}

/// Kelompok aset tetap menurut Pasal 11 UU PPh.
enum KelompokAsetTetap {
  BANGUNAN_PERMANEN // 20 tahun
  BANGUNAN_NON_PERMANEN // 10 tahun
  KELOMPOK_I // 4 tahun (peralatan, komputer)
  KELOMPOK_II // 8 tahun (kendaraan, mesin)
  KELOMPOK_III // 16 tahun
  KELOMPOK_IV // 20 tahun
}

/// Metode penyusutan.
enum MetodePenyusutan {
  GARIS_LURUS // wajib untuk bangunan (Pasal 11 UU PPh)
  SALDO_MENURUN // boleh untuk non-bangunan
}

/// Jenis mutasi stok di kartu stok.
enum ProjectStatus {
  AKTIF
  SELESAI
  DIBATALKAN
}

enum ProjectMemberRole {
  MANAGER // approve override budget, kelola member
  MEMBER // input transaksi ber-project ini
}

enum StokMovementType {
  STOK_AWAL // saldo awal saat onboarding
  PEMBELIAN // dari faktur pembelian (inbound)
  RETUR_BELI // retur ke vendor (outbound)
  PENJUALAN // dari faktur penjualan (outbound)
  RETUR_JUAL // dari pelanggan kembali (inbound)
  OPNAME_PLUS // hasil opname > pencatatan
  OPNAME_MINUS // hasil opname < pencatatan (rusak/hilang)
  TRANSFER_IN // dari cabang lain (Fase 5.1)
  TRANSFER_OUT
}

// ===============================================================
// IDENTITY (lintas tenant)
// ===============================================================

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  nama         String
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  memberships    Membership[]
  refreshTokens  RefreshToken[]
  projectMembers ProjectMember[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ===============================================================
// TENANCY
// ===============================================================

model Tenant {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Nama badan usaha (PT / CV / UD / Koperasi)
  nama       String
  /// NPWP pusat (15-16 digit, era Coretax)
  npwp       String?
  /// PKP atau bukan
  isPkp      Boolean    @default(false) @map("is_pkp")
  /// Pengukuhan PKP (untuk header faktur)
  pkpNo      String?    @map("pkp_no")
  alamat     String?
  email      String?
  telp       String?
  /// Path relatif logo perusahaan (mis. /uploads/logos/xxx.png), disimpan di disk API.
  logoUrl    String?    @map("logo_url")
  /// Tahun buku — default kalender
  tahunBuku  Int        @default(1) @map("tahun_buku")
  /// Metode harga pokok persediaan. Sekali ada transaksi, jangan diubah.
  costMethod CostMethod @default(AVERAGE) @map("cost_method")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  cabang             Cabang[]
  memberships        Membership[]
  accounts           Account[]
  taxRates           TaxRate[]
  items              Item[]
  vendors            Vendor[]
  customers          Customer[]
  fiscalYears        FiscalYear[]
  fiscalPeriods      FiscalPeriod[]
  journals           Journal[]
  sequences          Sequence[]
  salesInvoices      SalesInvoice[]
  purchaseInvoices   PurchaseInvoice[]
  cashBank           CashBankEntry[]
  stokMovements      StokMovement[]
  stokLots           StokLot[]
  stokAdjustments    StokAdjustment[]
  asetTetap          AsetTetap[]
  depresiasiRuns     DepresiasiRun[]
  karyawan           Karyawan[]
  payrollRuns        PayrollRun[]
  buktiPotong        BuktiPotong[]
  auditLogs          AuditLog[]
  glConfig           GlConfig[]
  projects           Project[]
  industri           Industri[]
  budgets            Budget[]
  pph23Tarif         Pph23Tarif[]
  saldoAwal          SaldoAwal[]
  saldoAwalAkunLines SaldoAwalAkunLine[]

  @@map("tenants")
}

model Cabang {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  /// Kode internal cabang (mis. "JKT", "SBY-01")
  kode           String
  nama           String
  /// 3 digit terakhir kode cabang NPWP (000 = pusat, 001+ = cabang)
  kodeCabangNpwp String?  @map("kode_cabang_npwp") @db.VarChar(3)
  /// NPWP cabang penuh (kalau berbeda dengan pusat — lazim untuk cabang fisik berbeda kota)
  npwpCabang     String?  @map("npwp_cabang")
  alamat         String?
  isPusat        Boolean  @default(false) @map("is_pusat")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipCabang MembershipCabang[]
  itemStokAwal     ItemStokAwal[]
  journals         Journal[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  cashBank         CashBankEntry[]
  stokMovements    StokMovement[]
  stokLots         StokLot[]
  stokAdjustments  StokAdjustment[]
  asetTetap        AsetTetap[]
  karyawan         Karyawan[]
  payrollRuns      PayrollRun[]
  buktiPotong      BuktiPotong[]
  saldoAwal        SaldoAwal[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@map("cabang")
}

model Membership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang MembershipCabang[]

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("memberships")
}

/// Akses per-cabang. Kalau kosong (tidak ada baris) → user dianggap punya akses semua cabang.
model MembershipCabang {
  membershipId String @map("membership_id") @db.Uuid
  cabangId     String @map("cabang_id") @db.Uuid

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  cabang     Cabang     @relation(fields: [cabangId], references: [id], onDelete: Cascade)

  @@id([membershipId, cabangId])
  @@map("membership_cabang")
}

// ===============================================================
// MASTER: COA (Chart of Accounts) — per tenant, shared antar cabang
// ===============================================================

model Account {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  parentId      String?       @map("parent_id") @db.Uuid
  /// Nomor akun, mis. "1-101", "1-1021"
  kode          String
  nama          String
  kind          AccountKind
  normalBalance NormalBalance @map("normal_balance")
  /// Akun postable (hanya leaf yang boleh dijurnal); parent = false.
  isPostable    Boolean       @default(true) @map("is_postable")
  isActive      Boolean       @default(true) @map("is_active")
  /// Klasifikasi Neraca (lancar/tetap, pendek/panjang). Dibaca laporan Neraca
  /// & Arus Kas — bukan lagi ditebak dari prefix kode. Null → laporan fallback
  /// ke konvensi prefix. Hanya relevan untuk kind ASET & LIABILITAS.
  klasifikasiNeraca KlasifikasiNeraca? @map("klasifikasi_neraca")
  /// Kas & setara kas. Dipakai laporan Arus Kas untuk menentukan saldo kas.
  isKasSetara   Boolean       @default(false) @map("is_kas_setara")
  /// Saldo awal periode pertama (opsional, dipakai saat onboarding).
  saldoAwal     Decimal       @default(0) @map("saldo_awal") @db.Decimal(20, 2)
  catatan       String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Account?  @relation("AccountTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Account[] @relation("AccountTree")

  itemPendapatan      Item[]                @relation("ItemPendapatan")
  itemPersediaan      Item[]                @relation("ItemPersediaan")
  itemHpp             Item[]                @relation("ItemHpp")
  itemBeban           Item[]                @relation("ItemBeban")
  vendorUtang         Vendor[]              @relation("VendorAkunUtang")
  customerPiutang     Customer[]            @relation("CustomerAkunPiutang")
  journalLines        JournalLine[]
  salesAR             SalesInvoice[]        @relation("SalesAR")
  purchaseAP          PurchaseInvoice[]     @relation("PurchaseAP")
  salesLineAccount    SalesInvoiceLine[]    @relation("SalesLineAccount")
  purchaseLineAccount PurchaseInvoiceLine[] @relation("PurchaseLineAccount")
  cashBank            CashBankEntry[]
  cashBankLines       CashBankEntryLine[]
  asetAset            AsetTetap[]           @relation("AsetAkunAset")
  asetAkumulasi       AsetTetap[]           @relation("AsetAkunAkumulasi")
  asetBeban           AsetTetap[]           @relation("AsetAkunBeban")
  glConfig            GlConfig[]
  budgets             Budget[]
  saldoAwalAkunLines  SaldoAwalAkunLine[]
  bankReconciliations BankReconciliation[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("accounts")
}

/// Pemetaan akun default untuk auto-posting jurnal yang sebelumnya hardcoded
/// (opname, disposal aset, payroll, laporan keuangan, dst).
/// Key string enum-like di GlConfigKey (shared/enums).
/// Service pakai pola: `glConfig.getAccountId('BEBAN_GAJI')`.
model GlConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  /// Key konstan (mis. 'BEBAN_GAJI', 'LABA_DITAHAN'). Lihat GlConfigKey.
  key       String
  accountId String   @map("account_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("gl_config")
}

// ===============================================================
// MASTER: tarif pajak (per tenant — bisa override default)
// ===============================================================

model TaxRate {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  /// Kode unik, mis. "PPN-11", "PPN-12", "PPH23-JASA"
  kode          String
  nama          String
  /// Tarif dalam persen (mis. 11, 12, 2, 15)
  tarif         Decimal   @db.Decimal(7, 4)
  /// Skema PPN (null untuk pajak non-PPN)
  ppnSkema      PpnSkema? @map("ppn_skema")
  /// Default akun utang/piutang pajak yang dipakai posting
  akunUtangId   String?   @map("akun_utang_id") @db.Uuid
  akunPiutangId String?   @map("akun_piutang_id") @db.Uuid
  isAktif       Boolean   @default(true) @map("is_aktif")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@map("tax_rates")
}

/// Database referensi tarif PPh 23 per jenis jasa (UU PPh Pasal 23 + PMK
/// 141/2015). Dipakai untuk auto-fill tarifPph23Persen saat item jasa
/// dibeli. Nilai standar: 2% (jasa umum), 15% (royalti/dividen/bunga/hadiah).
model Pph23Tarif {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  /// Kode singkat, mis. "JASA-TEKNIK", "ROYALTI", "JASA-KONSTRUKSI"
  kode       String
  /// Nama jenis jasa/penghasilan (dari Lampiran PMK 141/2015).
  nama       String
  /// Tarif dalam persen (2 atau 15 standar; boleh custom).
  tarif      Decimal  @db.Decimal(5, 2)
  /// Catatan/keterangan tambahan (mis. "dengan NPWP" atau spec dari PMK).
  keterangan String?
  isAktif    Boolean  @default(true) @map("is_aktif")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  Item[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@map("pph23_tarif")
}

// ===============================================================
// MASTER: Item (Barang & Jasa)
// ===============================================================

model Item {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  /// SKU internal, mis. "BRG-001"
  kode             String
  nama             String
  kategori         String?
  /// Satuan default: Pcs, Sak, Karton, Tray, Box, dst.
  satuan           String         @default("Pcs")
  /// Harga jual default (boleh di-override per faktur).
  hargaJualDefault Decimal        @default(0) @map("harga_jual_default") @db.Decimal(20, 2)
  /// Klasifikasi PPN — menentukan apakah kena PPN dan skema apa.
  klasifikasiPpn   KlasifikasiPpn @default(BKP) @map("klasifikasi_ppn")
  /// Apakah item ini jasa (sehingga juga kena PPh 23) atau barang dagang.
  isJasa           Boolean        @default(false) @map("is_jasa")
  /// Kode satuan barang menurut DJP (opsional, dipakai saat generate e-Faktur XML).
  kodeSatuanDjp    String?        @map("kode_satuan_djp")
  /// Akun default untuk posting jurnal — override per item dari setting tenant.
  akunPendapatanId String?        @map("akun_pendapatan_id") @db.Uuid
  akunPersediaanId String?        @map("akun_persediaan_id") @db.Uuid
  akunHppId        String?        @map("akun_hpp_id") @db.Uuid
  /// Akun beban kalau item dibeli sebagai jasa/bukan resale (mis. jasa konsultan).
  akunBebanId      String?        @map("akun_beban_id") @db.Uuid
  /// Tarif PPh 23 preset — hanya relevan kalau isJasa=true. Auto-fill ke
  /// purchase line saat item ini dipilih.
  pph23TarifId     String?        @map("pph23_tarif_id") @db.Uuid
  isAktif          Boolean        @default(true) @map("is_aktif")
  catatan          String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  akunPendapatan      Account?              @relation("ItemPendapatan", fields: [akunPendapatanId], references: [id], onDelete: SetNull)
  akunPersediaan      Account?              @relation("ItemPersediaan", fields: [akunPersediaanId], references: [id], onDelete: SetNull)
  akunHpp             Account?              @relation("ItemHpp", fields: [akunHppId], references: [id], onDelete: SetNull)
  akunBeban           Account?              @relation("ItemBeban", fields: [akunBebanId], references: [id], onDelete: SetNull)
  pph23Tarif          Pph23Tarif?           @relation(fields: [pph23TarifId], references: [id], onDelete: SetNull)
  stokAwal            ItemStokAwal[]
  salesLines          SalesInvoiceLine[]
  purchaseLines       PurchaseInvoiceLine[]
  stokMovements       StokMovement[]
  stokLots            StokLot[]
  stokAdjustmentLines StokAdjustmentLine[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@index([tenantId, isAktif])
  @@map("items")
}

/// Stok awal per item per cabang — dipakai saat onboarding & engine kartu stok (Fase 5).
model ItemStokAwal {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  itemId            String   @map("item_id") @db.Uuid
  cabangId          String   @map("cabang_id") @db.Uuid
  /// Jumlah unit pada tanggal saldo awal.
  qty               Decimal  @db.Decimal(20, 4)
  /// Harga pokok per unit (untuk valuasi persediaan awal).
  hargaPokokPerUnit Decimal  @map("harga_pokok_per_unit") @db.Decimal(20, 2)
  tanggal           DateTime @db.Date
  /// Non-null kalau baris ini sudah diposting lewat prosedur Saldo Awal
  /// Terintegrasi (StokMovement + jurnal GL sudah dibuat) — idempotency marker.
  saldoAwalId       String?  @map("saldo_awal_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")

  item      Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  cabang    Cabang     @relation(fields: [cabangId], references: [id], onDelete: Cascade)
  saldoAwal SaldoAwal? @relation(fields: [saldoAwalId], references: [id], onDelete: SetNull)

  @@unique([itemId, cabangId, tanggal])
  @@index([tenantId])
  @@index([itemId, cabangId])
  @@map("item_stok_awal")
}

/// Satu "sesi" prosedur saldo awal terintegrasi per tenant — mengorkestrasi
/// saldo awal akun manual (Kas/Aset Tetap/Modal/dst) + piutang per customer +
/// utang per vendor + persediaan per item SEKALIGUS dalam satu transaksi
/// atomik, supaya Neraca (Aset = Liabilitas + Ekuitas) selalu balance sejak
/// hari pertama. Lihat GlConfigKey.SALDO_AWAL_KLIRING untuk akun lawannya.
model SaldoAwal {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  /// Cabang default untuk jurnal akun manual (akun manual tidak per-cabang).
  cabangId            String        @map("cabang_id") @db.Uuid
  /// Tanggal cutover — wajib = startDate FiscalYear pertama tenant.
  tanggal             DateTime      @db.Date
  status              InvoiceStatus @default(DRAFT)
  totalDebit          Decimal       @default(0) @map("total_debit") @db.Decimal(20, 2)
  totalKredit         Decimal       @default(0) @map("total_kredit") @db.Decimal(20, 2)
  postedAt            DateTime?     @map("posted_at")
  postedById          String?       @map("posted_by_id") @db.Uuid
  postedRequestedById String?       @map("posted_requested_by_id") @db.Uuid
  cancelledAt         DateTime?     @map("cancelled_at")
  cancelledById       String?       @map("cancelled_by_id") @db.Uuid
  createdById         String?       @map("created_by_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang           Cabang              @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  akunLines        SaldoAwalAkunLine[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  itemStokAwal     ItemStokAwal[]

  @@unique([tenantId])
  @@map("saldo_awal")
}

/// Snapshot audit nilai Account.saldoAwal (akun manual non-subsidiary) SAAT
/// diposting — Account.saldoAwal sendiri di-reset ke 0 setelah posting
/// (nilainya "pindah" ke jurnal GL), baris ini jadi jejak historis + sumber
/// restore kalau run di-void.
model SaldoAwalAkunLine {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  saldoAwalId String   @map("saldo_awal_id") @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  /// Magnitude, tanda mengikuti account.normalBalance (konvensi sama dengan Account.saldoAwal).
  nilai       Decimal  @db.Decimal(20, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  saldoAwal SaldoAwal @relation(fields: [saldoAwalId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([saldoAwalId, accountId])
  @@index([tenantId])
  @@map("saldo_awal_akun_lines")
}

// ===============================================================
// MASTER: Vendor (Pemasok)
// ===============================================================

model Vendor {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  kode          String
  nama          String
  /// NPWP 15/16 digit (era Coretax — NIK juga valid untuk OP).
  npwp          String?
  /// Apakah vendor adalah PKP (penting untuk PPN masukan).
  isPkp         Boolean  @default(false) @map("is_pkp")
  kategori      String?
  alamat        String?
  kota          String?
  provinsi      String?
  kodePos       String?  @map("kode_pos")
  telp          String?
  email         String?
  contactPerson String?  @map("contact_person")
  /// Termin pembayaran dalam hari (default 30).
  terminHari    Int      @default(30) @map("termin_hari")
  /// Override akun utang usaha default (kalau null pakai 2-101).
  akunUtangId   String?  @map("akun_utang_id") @db.Uuid
  isAktif       Boolean  @default(true) @map("is_aktif")
  catatan       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  akunUtang        Account?          @relation("VendorAkunUtang", fields: [akunUtangId], references: [id], onDelete: SetNull)
  purchaseInvoices PurchaseInvoice[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@index([tenantId, isAktif])
  @@map("vendors")
}

// ===============================================================
// MASTER: Customer (Pelanggan)
// ===============================================================

model Customer {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  kode          String
  nama          String
  npwp          String?
  isPkp         Boolean      @default(false) @map("is_pkp")
  tipe          TipeCustomer @default(RITEL)
  alamat        String?
  kota          String?
  provinsi      String?
  kodePos       String?      @map("kode_pos")
  telp          String?
  email         String?
  contactPerson String?      @map("contact_person")
  terminHari    Int          @default(14) @map("termin_hari")
  /// Batas kredit pelanggan (untuk validasi penjualan kredit).
  kreditLimit   Decimal      @default(0) @map("kredit_limit") @db.Decimal(20, 2)
  /// Override akun piutang usaha (kalau null pakai 1-103).
  akunPiutangId String?      @map("akun_piutang_id") @db.Uuid
  isAktif       Boolean      @default(true) @map("is_aktif")
  catatan       String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  akunPiutang   Account?       @relation("CustomerAkunPiutang", fields: [akunPiutangId], references: [id], onDelete: SetNull)
  salesInvoices SalesInvoice[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@index([tenantId, isAktif])
  @@map("customers")
}

// ===============================================================
// PERIOD MANAGEMENT
// ===============================================================

model FiscalYear {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  /// Label tahun buku, mis. "2026". Boleh non-kalender ("2026/2027").
  kode       String
  startDate  DateTime         @map("start_date") @db.Date
  endDate    DateTime         @map("end_date") @db.Date
  status     FiscalYearStatus @default(OPEN)
  closedAt   DateTime?        @map("closed_at")
  closedById String?          @map("closed_by_id") @db.Uuid
  /// Catatan tutup/reopen tahun buku (audit trail), sama pola FiscalPeriod.catatanTutup.
  catatanTutup String?        @map("catatan_tutup")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periods FiscalPeriod[]

  @@unique([tenantId, kode])
  @@index([tenantId])
  @@map("fiscal_years")
}

model FiscalPeriod {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  fiscalYearId String       @map("fiscal_year_id") @db.Uuid
  /// Nomor periode dalam tahun buku (1-12 untuk bulanan).
  no           Int
  /// Label "Jan 2026", "Feb 2026", dst.
  label        String
  startDate    DateTime     @map("start_date") @db.Date
  endDate      DateTime     @map("end_date") @db.Date
  status       PeriodStatus @default(OPEN)
  closedAt     DateTime?    @map("closed_at")
  closedById   String?      @map("closed_by_id") @db.Uuid
  /// Catatan tutup buku (mis. "Audit Q1 selesai, dikunci").
  catatanTutup String?      @map("catatan_tutup")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear       FiscalYear        @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  journals         Journal[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  cashBank         CashBankEntry[]
  stokAdjustments  StokAdjustment[]
  depresiasiRuns   DepresiasiRun[]
  payrollRuns      PayrollRun[]
  buktiPotong      BuktiPotong[]

  @@unique([tenantId, fiscalYearId, no])
  @@index([tenantId])
  @@index([tenantId, startDate, endDate])
  @@map("fiscal_periods")
}

// ===============================================================
// GENERAL LEDGER: Journal (header) + JournalLine
// ===============================================================

model Journal {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  cabangId             String        @map("cabang_id") @db.Uuid
  fiscalPeriodId       String        @map("fiscal_period_id") @db.Uuid
  /// Auto-generated, format "JU-2026-05-0001" per tenant per bulan.
  /// Dialokasi saat .post(), bukan saat draft.
  nomor                String?
  tanggal              DateTime      @db.Date
  deskripsi            String
  /// URL bukti transaksi eksternal (scan/foto/gdrive/dropbox/dll). Optional.
  linkBukti            String?       @map("link_bukti")
  sumber               JournalSource @default(MANUAL)
  /// Pointer balik ke dokumen sumber (mis. invoice id) untuk telusur.
  sumberRef            String?       @map("sumber_ref")
  status               JournalStatus @default(DRAFT)
  /// Pointer ke jurnal asli kalau baris ini ADALAH jurnal pembalik.
  reversedFromId       String?       @map("reversed_from_id") @db.Uuid
  /// Pointer ke jurnal pembalik kalau baris ini DIBALIK oleh jurnal lain.
  reversedById         String?       @map("reversed_by_id") @db.Uuid
  /// Snapshot total saat post — dicheck D=K dan disimpan untuk perf.
  totalDebit           Decimal       @default(0) @map("total_debit") @db.Decimal(20, 2)
  totalKredit          Decimal       @default(0) @map("total_kredit") @db.Decimal(20, 2)
  postedAt             DateTime?     @map("posted_at")
  postedById           String?       @map("posted_by_id") @db.Uuid
  /// Step-up audit: kalau posting dieksekusi atas permintaan user lain
  /// (mis. KASIR meminta approval AKUNTAN), simpan ID requester di sini.
  /// postedById tetap menunjuk ke approver (yang JWT-nya dipakai).
  postedRequestedById  String?       @map("posted_requested_by_id") @db.Uuid
  /// Audit override budget: kalau posting menembus limit Budget dan approver
  /// (OWNER/ADMIN/MANAGER) mengizinkan, flag ini true + alasan disimpan.
  budgetOverridden     Boolean       @default(false) @map("budget_overridden")
  budgetOverrideAlasan String?       @map("budget_override_alasan")
  createdById          String?       @map("created_by_id") @db.Uuid
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang        @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  lines        JournalLine[]
  reversedFrom Journal?      @relation("JournalReversal", fields: [reversedFromId], references: [id], onDelete: SetNull)
  reversals    Journal[]     @relation("JournalReversal")

  @@unique([tenantId, nomor])
  @@index([tenantId])
  @@index([tenantId, status, tanggal])
  @@index([fiscalPeriodId, status])
  @@index([cabangId, tanggal])
  @@index([sumber, sumberRef])
  @@map("journals")
}

model JournalLine {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  journalId String  @map("journal_id") @db.Uuid
  accountId String  @map("account_id") @db.Uuid
  /// Attach transaksi ke project untuk budgeting + laporan per project.
  /// Nullable — baris tanpa project dianggap "overhead / general".
  projectId String? @map("project_id") @db.Uuid
  /// Urutan baris di voucher (1, 2, 3, ...).
  no        Int
  debit     Decimal @default(0) @db.Decimal(20, 2)
  kredit    Decimal @default(0) @db.Decimal(20, 2)
  deskripsi String?

  journal Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  bankReconLine BankReconciliationLine?

  @@index([journalId])
  @@index([tenantId, accountId])
  @@index([projectId, accountId])
  @@map("journal_lines")
}

/// Rekonsiliasi bank — mencocokkan saldo buku akun kas/bank terhadap saldo per
/// rekening koran pada tanggal cut-off. Baris jurnal yang sudah muncul di
/// rekening koran ditandai "cleared" (via BankReconciliationLine); sisanya jadi
/// item beredar (setoran dalam perjalanan / pembayaran belum kliring).
model BankReconciliation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  /// Cabang scope (opsional — akun kas/bank bisa lintas cabang).
  cabangId           String?  @map("cabang_id") @db.Uuid
  /// Akun kas/bank yang direkonsiliasi.
  akunId             String   @map("akun_id") @db.Uuid
  /// Tanggal cut-off / tanggal rekening koran.
  tanggal            DateTime @db.Date
  /// Saldo akhir per rekening koran bank (diinput user).
  saldoRekeningKoran Decimal  @map("saldo_rekening_koran") @db.Decimal(20, 2)
  /// Snapshot saldo buku (GL) akun pada cut-off — diisi saat finalize.
  saldoBuku          Decimal  @default(0) @map("saldo_buku") @db.Decimal(20, 2)
  /// Snapshot selisih (saldo buku − saldo bank disesuaikan) saat finalize.
  selisih            Decimal  @default(0) @db.Decimal(20, 2)
  status             BankReconciliationStatus @default(DRAFT)
  catatan            String?
  createdById        String?  @map("created_by_id") @db.Uuid
  finalizedAt        DateTime? @map("finalized_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  akun  Account @relation(fields: [akunId], references: [id], onDelete: Restrict)
  lines BankReconciliationLine[]

  @@index([tenantId, akunId])
  @@map("bank_reconciliations")
}

/// Satu baris jurnal yang ditandai sudah kliring di rekening koran. Unik per
/// journalLineId → sebuah baris hanya bisa "cleared" di satu rekonsiliasi.
model BankReconciliationLine {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  reconciliationId String   @map("reconciliation_id") @db.Uuid
  journalLineId    String   @unique @map("journal_line_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  journalLine    JournalLine        @relation(fields: [journalLineId], references: [id], onDelete: Cascade)

  @@index([reconciliationId])
  @@map("bank_reconciliation_lines")
}

/// Aturan approval berjenjang per jenis dokumen. Dokumen dengan nilai ≥
/// minAmount memicu aturan; aturan dgn minAmount tertinggi yang cocok dipakai.
model ApprovalRule {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  docType   ApprovalDocType @map("doc_type")
  /// Ambang nilai minimum (inklusif) yang memicu aturan ini.
  minAmount Decimal         @default(0) @map("min_amount") @db.Decimal(20, 2)
  isActive  Boolean         @default(true) @map("is_active")
  catatan   String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  steps ApprovalRuleStep[]

  @@index([tenantId, docType])
  @@map("approval_rules")
}

/// Satu langkah (tingkat) approval dalam sebuah aturan — approver = pemegang role.
model ApprovalRuleStep {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  ruleId       String @map("rule_id") @db.Uuid
  urutan       Int
  approverRole Role   @map("approver_role")

  rule ApprovalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, urutan])
  @@map("approval_rule_steps")
}

/// Permintaan approval untuk satu dokumen (polymorphic via docType+docId).
model ApprovalRequest {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  docType       ApprovalDocType @map("doc_type")
  docId         String          @map("doc_id") @db.Uuid
  cabangId      String?         @map("cabang_id") @db.Uuid
  amount        Decimal         @db.Decimal(20, 2)
  status        ApprovalStatus  @default(MENUNGGU)
  /// Langkah yang sedang menunggu persetujuan (1-based).
  currentStep   Int             @default(1) @map("current_step")
  totalSteps    Int             @map("total_steps")
  /// Snapshot role approver per langkah (CSV terurut, mis. "ADMIN,OWNER") —
  /// tahan terhadap perubahan aturan setelah request dibuat.
  stepRoles     String          @map("step_roles")
  requestedById String?         @map("requested_by_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  resolvedAt    DateTime?       @map("resolved_at")

  actions ApprovalAction[]

  @@index([tenantId, status])
  @@index([tenantId, docType, docId])
  @@map("approval_requests")
}

/// Jejak keputusan tiap langkah approval (setuju/tolak + oleh siapa).
model ApprovalAction {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  requestId      String             @map("request_id") @db.Uuid
  urutan         Int
  approverRole   Role               @map("approver_role")
  approverUserId String             @map("approver_user_id") @db.Uuid
  action         ApprovalActionType
  catatan        String?
  actedAt        DateTime           @default(now()) @map("acted_at")

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("approval_actions")
}

/// Generator nomor dokumen (per tenant per kode periodik).
/// Update pakai SELECT ... FOR UPDATE supaya tahan race condition.
model Sequence {
  tenantId  String   @map("tenant_id") @db.Uuid
  /// Kode unik, mis. "JU-2026-05", "INV-2026-05", "BILL-2026-05".
  kode      String
  /// Nomor terakhir yang sudah dialokasi (next = current + 1).
  current   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, kode])
  @@map("sequences")
}

// ===============================================================
// TRANSAKSI: Faktur Penjualan
// ===============================================================

model SalesInvoice {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  cabangId           String           @map("cabang_id") @db.Uuid
  fiscalPeriodId     String           @map("fiscal_period_id") @db.Uuid
  customerId         String           @map("customer_id") @db.Uuid
  /// Auto: INV-2026-05-0001, dialokasi saat .post()
  nomor              String?
  tanggal            DateTime         @db.Date
  jatuhTempo         DateTime         @map("jatuh_tempo") @db.Date
  termin             TerminPembayaran @default(KREDIT)
  /// Akun kas/bank untuk transaksi TUNAI, atau akun piutang untuk KREDIT
  /// (default dari customer.akunPiutangId).
  akunArId           String           @map("akun_ar_id") @db.Uuid
  status             InvoiceStatus    @default(DRAFT)
  deskripsi          String?
  /// Kalau true, hargaSatuan yang diinput user sudah include PPN (harga tag).
  /// Engine akan reverse-calc DPP = gross / (1 + tarifEfektif/100).
  /// Default false = harga excl PPN (mode existing).
  hargaTermasukPajak Boolean          @default(false) @map("harga_termasuk_pajak")
  /// URL bukti transaksi eksternal (scan invoice/PO/DO/foto tanda-tangan/dll).
  linkBukti          String?          @map("link_bukti")
  /// Faktur pajak data (untuk customer PKP)
  kodeFakturPajak    KodeFakturPajak? @map("kode_faktur_pajak")
  nsfp               String? // 16 digit nomor seri faktur pajak (Coretax)

  /// Snapshot total
  totalDpp     Decimal @default(0) @map("total_dpp") @db.Decimal(20, 2)
  totalPpn     Decimal @default(0) @map("total_ppn") @db.Decimal(20, 2)
  totalPph23   Decimal @default(0) @map("total_pph23") @db.Decimal(20, 2)
  totalDiskon  Decimal @default(0) @map("total_diskon") @db.Decimal(20, 2)
  totalNetto   Decimal @default(0) @map("total_netto") @db.Decimal(20, 2) // DPP + PPN - PPh23 (yg dibayar customer)
  /// Akumulasi pelunasan
  totalDibayar Decimal @default(0) @map("total_dibayar") @db.Decimal(20, 2)

  /// Link ke jurnal yang ter-post (AR/Pendapatan/PPN)
  journalId    String? @unique @map("journal_id") @db.Uuid
  /// Jurnal HPP terpisah (D HPP, K Persediaan) — terbit saat post kalau ada item barang.
  hppJournalId String? @unique @map("hpp_journal_id") @db.Uuid

  postedAt               DateTime? @map("posted_at")
  postedById             String?   @map("posted_by_id") @db.Uuid
  /// Step-up audit: ID user yang meminta posting saat dijalankan dengan
  /// approval kredensial (mis. KASIR meminta AKUNTAN approve). Null untuk
  /// posting langsung. postedById tetap = approver.
  postedRequestedById    String?   @map("posted_requested_by_id") @db.Uuid
  cancelledAt            DateTime? @map("cancelled_at")
  cancelledById          String?   @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?   @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?   @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  /// Entri piutang saldo awal (prosedur Saldo Awal Terintegrasi), bukan
  /// penjualan riil — .post() skip baris pendapatan/PPN/HPP/stok-outbound,
  /// langsung D akunArId / K akun kliring. Tetap muncul di aging/statement
  /// piutang seperti faktur biasa (by design — lihat opening-balance module).
  isSaldoAwal Boolean @default(false) @map("is_saldo_awal")
  saldoAwalId String? @map("saldo_awal_id") @db.Uuid

  /// Idempotency key opsional dari client (mis. double-submit form/retry
  /// jaringan) — createDraft() cek dulu sebelum insert, return row existing
  /// kalau sudah pernah dipakai. Nullable + unique per tenant: Postgres
  /// unique index abaikan baris NULL, jadi tidak breaking utk client lama
  /// yang belum kirim key.
  idempotencyKey String? @map("idempotency_key") @db.Uuid

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang             @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod       @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  akunAr       Account            @relation("SalesAR", fields: [akunArId], references: [id], onDelete: Restrict)
  saldoAwal    SaldoAwal?         @relation(fields: [saldoAwalId], references: [id], onDelete: SetNull)
  lines        SalesInvoiceLine[]

  @@unique([tenantId, nomor])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, tanggal])
  @@index([customerId, status])
  @@index([fiscalPeriodId])
  @@index([tenantId, isSaldoAwal])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  invoiceId      String         @map("invoice_id") @db.Uuid
  itemId         String?        @map("item_id") @db.Uuid
  no             Int
  /// Snapshot nama item saat faktur dibuat (tahan rename).
  deskripsi      String
  qty            Decimal        @db.Decimal(20, 4)
  satuan         String
  hargaSatuan    Decimal        @map("harga_satuan") @db.Decimal(20, 2)
  diskonPersen   Decimal        @default(0) @map("diskon_persen") @db.Decimal(7, 4)
  /// Klasifikasi PPN snapshot dari item; menentukan apakah baris ini kena PPN.
  klasifikasiPpn KlasifikasiPpn @map("klasifikasi_ppn")
  /// Snapshot apakah ini jasa (untuk PPh 23).
  isJasa         Boolean        @default(false) @map("is_jasa")

  /// Computed values (snapshot, in-sync dgn header total).
  bruto       Decimal @db.Decimal(20, 2) // qty * harga
  diskonNilai Decimal @default(0) @map("diskon_nilai") @db.Decimal(20, 2)
  dpp         Decimal @db.Decimal(20, 2) // bruto - diskon (atau adj. nilai lain)
  ppn         Decimal @default(0) @db.Decimal(20, 2)
  pph23       Decimal @default(0) @db.Decimal(20, 2)

  /// Akun pendapatan (default dari item.akunPendapatanId).
  akunPendapatanId String  @map("akun_pendapatan_id") @db.Uuid
  /// Attach ke project (opsional) — untuk laporan + budget per project.
  projectId        String? @map("project_id") @db.Uuid

  invoice        SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item           Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  akunPendapatan Account      @relation("SalesLineAccount", fields: [akunPendapatanId], references: [id], onDelete: Restrict)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([tenantId])
  @@index([projectId])
  @@map("sales_invoice_lines")
}

// ===============================================================
// TRANSAKSI: Tagihan Pembelian
// ===============================================================

model PurchaseInvoice {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  cabangId           String           @map("cabang_id") @db.Uuid
  fiscalPeriodId     String           @map("fiscal_period_id") @db.Uuid
  vendorId           String           @map("vendor_id") @db.Uuid
  /// Auto: BILL-2026-05-0001
  nomor              String?
  /// Nomor faktur dari pemasok (referensi eksternal, mis. faktur PPN mereka).
  nomorVendor        String?          @map("nomor_vendor")
  tanggal            DateTime         @db.Date
  jatuhTempo         DateTime         @map("jatuh_tempo") @db.Date
  termin             TerminPembayaran @default(KREDIT)
  /// Akun kas/bank (untuk TUNAI) atau utang usaha (untuk KREDIT)
  akunApId           String           @map("akun_ap_id") @db.Uuid
  status             InvoiceStatus    @default(DRAFT)
  deskripsi          String?
  /// Kalau true, hargaSatuan input sudah include PPN (harga tag vendor).
  /// Engine reverse-calc DPP dari gross.
  hargaTermasukPajak Boolean          @default(false) @map("harga_termasuk_pajak")
  /// URL bukti tagihan eksternal (scan faktur vendor/PO/DO/dll).
  linkBukti          String?          @map("link_bukti")
  /// Faktur pajak masukan dari vendor (untuk vendor PKP).
  nsfpMasukan        String?          @map("nsfp_masukan")

  totalDpp     Decimal @default(0) @map("total_dpp") @db.Decimal(20, 2)
  totalPpn     Decimal @default(0) @map("total_ppn") @db.Decimal(20, 2)
  totalPph23   Decimal @default(0) @map("total_pph23") @db.Decimal(20, 2)
  totalDiskon  Decimal @default(0) @map("total_diskon") @db.Decimal(20, 2)
  /// DPP + PPN - PPh23 yg dipotong = yang kita bayar ke vendor
  totalNetto   Decimal @default(0) @map("total_netto") @db.Decimal(20, 2)
  totalDibayar Decimal @default(0) @map("total_dibayar") @db.Decimal(20, 2)

  journalId String? @unique @map("journal_id") @db.Uuid

  postedAt               DateTime? @map("posted_at")
  postedById             String?   @map("posted_by_id") @db.Uuid
  /// Step-up audit: ID user yang meminta posting saat dijalankan dengan
  /// approval kredensial (mis. KASIR meminta AKUNTAN approve). Null untuk
  /// posting langsung. postedById tetap = approver.
  postedRequestedById    String?   @map("posted_requested_by_id") @db.Uuid
  cancelledAt            DateTime? @map("cancelled_at")
  cancelledById          String?   @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?   @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?   @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  /// Entri utang saldo awal (prosedur Saldo Awal Terintegrasi) — lihat
  /// catatan analog di SalesInvoice.isSaldoAwal.
  isSaldoAwal Boolean @default(false) @map("is_saldo_awal")
  saldoAwalId String? @map("saldo_awal_id") @db.Uuid

  /// Idempotency key opsional dari client — lihat catatan analog di
  /// SalesInvoice.idempotencyKey.
  idempotencyKey String? @map("idempotency_key") @db.Uuid

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang                @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod          @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  vendor       Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  akunAp       Account               @relation("PurchaseAP", fields: [akunApId], references: [id], onDelete: Restrict)
  saldoAwal    SaldoAwal?            @relation(fields: [saldoAwalId], references: [id], onDelete: SetNull)
  lines        PurchaseInvoiceLine[]

  @@unique([tenantId, nomor])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, tanggal])
  @@index([vendorId, status])
  @@index([fiscalPeriodId])
  @@index([tenantId, isSaldoAwal])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
