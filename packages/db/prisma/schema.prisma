// ===============================================================
// TRANSAKSI: Kas & Bank (BKM/BKK/BBM/BBK & transfer internal)
// ===============================================================

model CashBankEntry {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  cabangId           String        @map("cabang_id") @db.Uuid
  fiscalPeriodId     String        @map("fiscal_period_id") @db.Uuid
  /// Auto: BKM/BKK/BBM/BBK-2026-05-0001
  nomor              String?
  tanggal            DateTime      @db.Date
  tipe               CashBankType
  /// Akun kas/bank utama yang dipengaruhi (debit kalau RECEIPT, kredit kalau PAYMENT).
  akunKasBankId      String        @map("akun_kas_bank_id") @db.Uuid
  /// Total transaksi (positif). Untuk TRANSFER, sama dgn akunKasBankLawanId.
  total              Decimal       @db.Decimal(20, 2)
  /// Untuk TRANSFER: akun kas/bank lawan.
  akunKasBankLawanId String?       @map("akun_kas_bank_lawan_id") @db.Uuid
  /// Pihak transaksi (label saja). Untuk pelunasan AR/AP, link via salesInvoiceId/purchaseInvoiceId.
  kontak             String?
  deskripsi          String?
  /// URL bukti transaksi eksternal (scan slip bank/BKM/BKK, foto struk, dll).
  linkBukti          String?       @map("link_bukti")
  status             InvoiceStatus @default(DRAFT)
  /// Link optional untuk pelunasan AR/AP.
  salesInvoiceId     String?       @map("sales_invoice_id") @db.Uuid
  purchaseInvoiceId  String?       @map("purchase_invoice_id") @db.Uuid
  /// PPh 23 yang dipotong pelanggan saat pelunasan piutang JKP (hanya RECEIPT).
  /// Kas masuk = total − pph23Dipotong; sisanya dibukukan ke PPh 23 Dibayar Dimuka.
  pph23Dipotong      Decimal       @default(0) @map("pph23_dipotong") @db.Decimal(20, 2)
  /// Nomor bukti potong PPh 23 yang diterima dari pelanggan (arsip pajak).
  noBuktiPotong      String?       @map("no_bukti_potong")

  journalId              String?   @unique @map("journal_id") @db.Uuid
  postedAt               DateTime? @map("posted_at")
  postedById             String?   @map("posted_by_id") @db.Uuid
  cancelledAt            DateTime? @map("cancelled_at")
  cancelledById          String?   @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?   @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?   @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang              @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod        @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  akunKasBank  Account             @relation(fields: [akunKasBankId], references: [id], onDelete: Restrict)
  lines        CashBankEntryLine[]

  @@unique([tenantId, nomor])
  @@index([tenantId, status, tanggal])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
  @@map("cash_bank_entries")
}

/// Baris lawan transaksi kas/bank.
/// Untuk RECEIPT: tiap baris menjadi KREDIT (lawan dari debit kas/bank).
/// Untuk PAYMENT: tiap baris menjadi DEBIT (lawan dari kredit kas/bank).
/// Untuk TRANSFER: tidak ada baris (akun lawan di header).
model CashBankEntryLine {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  entryId   String  @map("entry_id") @db.Uuid
  no        Int
  /// Akun lawan (mis. piutang, utang, pendapatan lain, beban).
  accountId String  @map("account_id") @db.Uuid
  /// Attach ke project (opsional) — untuk laporan + budget per project.
  projectId String? @map("project_id") @db.Uuid
  nilai     Decimal @db.Decimal(20, 2)
  deskripsi String?

  entry   CashBankEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  project Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([entryId])
  @@index([tenantId])
  @@index([projectId])
  @@map("cash_bank_entry_lines")
}

// ===============================================================
// INVENTORY (Fase 5): kartu stok, lot FIFO, opname
// ===============================================================

/// Setiap event yang mempengaruhi stok — sumber tunggal kebenaran untuk kartu stok.
/// Saldo running disimpan per baris supaya report kartu stok cepat (tidak perlu re-aggregate).
model StokMovement {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  itemId     String           @map("item_id") @db.Uuid
  cabangId   String           @map("cabang_id") @db.Uuid
  tanggal    DateTime         @db.Date
  /// Timestamp asli supaya urutan dalam satu hari tetap stabil.
  occurredAt DateTime         @default(now()) @map("occurred_at")
  tipe       StokMovementType
  /// Salah satu di antara qtyIn/qtyOut harus > 0 (CHECK di SQL).
  qtyIn      Decimal          @default(0) @map("qty_in") @db.Decimal(20, 4)
  qtyOut     Decimal          @default(0) @map("qty_out") @db.Decimal(20, 4)
  /// Harga pokok per unit pada movement ini.
  hargaPokok Decimal          @map("harga_pokok") @db.Decimal(20, 4)
  /// Nilai movement signed (+ inbound, - outbound).
  nilai      Decimal          @db.Decimal(20, 2)
  /// Saldo BERJALAN setelah movement ini (per item per cabang).
  saldoQty   Decimal          @map("saldo_qty") @db.Decimal(20, 4)
  saldoNilai Decimal          @map("saldo_nilai") @db.Decimal(20, 2)
  /// Telusur balik: 'SALES_LINE' / 'PURCHASE_LINE' / 'ADJUSTMENT_LINE' / 'STOK_AWAL'.
  sumberType String?          @map("sumber_type")
  sumberId   String?          @map("sumber_id")
  keterangan String?
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item     Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  cabang   Cabang            @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  lots     StokLot[]         @relation("StokLotMasuk")
  konsumsi StokLotKonsumsi[]

  @@index([tenantId, itemId, cabangId, occurredAt])
  @@index([sumberType, sumberId])
  @@map("stok_movements")
}

/// Lot persediaan untuk FIFO — satu lot per movement INBOUND.
/// Saat OUTBOUND, lot tertua diambil dulu sampai habis (boleh pecah).
model StokLot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  cabangId        String   @map("cabang_id") @db.Uuid
  tanggalMasuk    DateTime @map("tanggal_masuk") @db.Date
  occurredAt      DateTime @default(now()) @map("occurred_at")
  qtyMasuk        Decimal  @map("qty_masuk") @db.Decimal(20, 4)
  qtyTerpakai     Decimal  @default(0) @map("qty_terpakai") @db.Decimal(20, 4)
  hargaPokok      Decimal  @map("harga_pokok") @db.Decimal(20, 4)
  /// Pointer ke movement masuk yang membuat lot ini.
  movementMasukId String   @map("movement_masuk_id") @db.Uuid

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item          Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  cabang        Cabang            @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  movementMasuk StokMovement      @relation("StokLotMasuk", fields: [movementMasukId], references: [id], onDelete: Restrict)
  konsumsi      StokLotKonsumsi[]

  @@index([tenantId, itemId, cabangId, occurredAt])
  @@map("stok_lots")
}

/// Konsumsi lot oleh movement outbound (FIFO). Satu outbound bisa habiskan beberapa lot.
model StokLotKonsumsi {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  lotId         String  @map("lot_id") @db.Uuid
  movementOutId String  @map("movement_out_id") @db.Uuid
  qty           Decimal @db.Decimal(20, 4)
  hargaPokok    Decimal @map("harga_pokok") @db.Decimal(20, 4)

  lot         StokLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  movementOut StokMovement @relation(fields: [movementOutId], references: [id], onDelete: Cascade)

  @@index([tenantId, lotId])
  @@index([movementOutId])
  @@map("stok_lot_konsumsi")
}

/// Opname / penyesuaian stok manual.
model StokAdjustment {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  cabangId               String        @map("cabang_id") @db.Uuid
  fiscalPeriodId         String        @map("fiscal_period_id") @db.Uuid
  /// Auto: ADJ-2026-05-0001
  nomor                  String?
  tanggal                DateTime      @db.Date
  alasan                 String // mis. "Opname akhir Mei 2026", "Rusak gudang"
  status                 InvoiceStatus @default(DRAFT)
  journalId              String?       @unique @map("journal_id") @db.Uuid
  totalDeltaNilai        Decimal       @default(0) @map("total_delta_nilai") @db.Decimal(20, 2)
  postedAt               DateTime?     @map("posted_at")
  postedById             String?       @map("posted_by_id") @db.Uuid
  /// Step-up audit: requester ID kalau posting dengan approval kredensial.
  postedRequestedById    String?       @map("posted_requested_by_id") @db.Uuid
  cancelledAt            DateTime?     @map("cancelled_at")
  cancelledById          String?       @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?       @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?       @map("created_by_id") @db.Uuid
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang               @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod         @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  lines        StokAdjustmentLine[]

  @@unique([tenantId, nomor])
  @@index([tenantId, status, tanggal])
  @@map("stok_adjustments")
}

model StokAdjustmentLine {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  adjustmentId String  @map("adjustment_id") @db.Uuid
  itemId       String  @map("item_id") @db.Uuid
  no           Int
  /// Snapshot saldo pencatatan saat draft dibuat.
  qtySaatIni   Decimal @map("qty_saat_ini") @db.Decimal(20, 4)
  /// Hasil fisik (opname).
  qtyFisik     Decimal @map("qty_fisik") @db.Decimal(20, 4)
  /// Delta = qtyFisik - qtySaatIni. Boleh + atau -.
  delta        Decimal @db.Decimal(20, 4)
  /// Harga pokok untuk valuasi (pakai saldoNilai/saldoQty saat snapshot).
  hargaPokok   Decimal @map("harga_pokok") @db.Decimal(20, 4)
  /// Signed: delta × hargaPokok.
  nilaiDelta   Decimal @map("nilai_delta") @db.Decimal(20, 2)
  keterangan   String?

  adjustment StokAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  item       Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([adjustmentId])
  @@index([tenantId])
  @@map("stok_adjustment_lines")
}

// ===============================================================
// ASET TETAP (Fase 6) — Pasal 11 UU PPh + penyusutan bulanan
// ===============================================================

model AsetTetap {
  id       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String            @map("tenant_id") @db.Uuid
  cabangId String            @map("cabang_id") @db.Uuid
  /// Kode internal, mis. AT-001
  kode     String
  nama     String
  /// Kelompok aset menurut Pasal 11 UU PPh — menentukan default masa manfaat.
  kelompok KelompokAsetTetap
  /// Metode penyusutan. Bangunan WAJIB GARIS_LURUS (UU PPh).
  metode   MetodePenyusutan  @default(GARIS_LURUS)

  tanggalPerolehan DateTime @map("tanggal_perolehan") @db.Date
  /// Tanggal mulai penyusutan (umumnya bulan setelah perolehan, bisa diatur).
  mulaiPenyusutan  DateTime @map("mulai_penyusutan") @db.Date

  hargaPerolehan   Decimal @map("harga_perolehan") @db.Decimal(20, 2)
  /// Nilai sisa pada akhir masa manfaat (umumnya 0).
  nilaiResidu      Decimal @default(0) @map("nilai_residu") @db.Decimal(20, 2)
  /// Masa manfaat dalam BULAN (Kelompok I = 48, II = 96, III = 192, IV = 240, Bangunan 240, NonPerm 120).
  masaManfaatBulan Int     @map("masa_manfaat_bulan")

  /// Snapshot — sumber kebenaran adalah DepresiasiLine, tapi cache di sini supaya cepat.
  akumulasiPenyusutan   Decimal @default(0) @map("akumulasi_penyusutan") @db.Decimal(20, 2)
  nilaiBuku             Decimal @map("nilai_buku") @db.Decimal(20, 2)
  /// "YYYY-MM" periode terakhir yang sudah dihitung penyusutannya.
  lastDepresiasiPeriode String? @map("last_depresiasi_periode")

  /// Akun aset (debit saat perolehan, kredit saat dijual).
  akunAsetId      String @map("akun_aset_id") @db.Uuid
  /// Akun akumulasi (kontra-aset, kredit per bulan, debit saat dijual).
  akunAkumulasiId String @map("akun_akumulasi_id") @db.Uuid
  /// Akun beban penyusutan (debit per bulan).
  akunBebanId     String @map("akun_beban_id") @db.Uuid

  status  AsetStatus @default(AKTIF)
  catatan String?

  /// Diisi saat dispose.
  tanggalDihentikan DateTime? @map("tanggal_dihentikan") @db.Date
  hargaJualDisposal Decimal?  @map("harga_jual_disposal") @db.Decimal(20, 2)
  disposalJournalId String?   @unique @map("disposal_journal_id") @db.Uuid

  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang          Cabang           @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  akunAset        Account          @relation("AsetAkunAset", fields: [akunAsetId], references: [id], onDelete: Restrict)
  akunAkumulasi   Account          @relation("AsetAkunAkumulasi", fields: [akunAkumulasiId], references: [id], onDelete: Restrict)
  akunBeban       Account          @relation("AsetAkunBeban", fields: [akunBebanId], references: [id], onDelete: Restrict)
  depresiasiLines DepresiasiLine[]

  @@unique([tenantId, kode])
  @@index([tenantId, status])
  @@index([cabangId])
  @@map("aset_tetap")
}

/// Run penyusutan bulanan — 1 per (tenant, periode YYYY-MM).
model DepresiasiRun {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  fiscalPeriodId  String        @map("fiscal_period_id") @db.Uuid
  /// "YYYY-MM" — kunci uniqueness untuk cegah double-run.
  periode         String
  /// Tanggal posting jurnal (umumnya akhir bulan).
  tanggal         DateTime      @db.Date
  status          InvoiceStatus @default(DRAFT)
  journalId       String?       @unique @map("journal_id") @db.Uuid
  totalPenyusutan Decimal       @default(0) @map("total_penyusutan") @db.Decimal(20, 2)

  postedAt               DateTime? @map("posted_at")
  postedById             String?   @map("posted_by_id") @db.Uuid
  cancelledAt            DateTime? @map("cancelled_at")
  cancelledById          String?   @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?   @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?   @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod     @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  lines        DepresiasiLine[]

  @@unique([tenantId, periode])
  @@index([tenantId, status])
  @@map("depresiasi_runs")
}

model DepresiasiLine {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  runId            String  @map("run_id") @db.Uuid
  asetId           String  @map("aset_id") @db.Uuid
  /// Penyusutan untuk bulan ini saja.
  nilai            Decimal @db.Decimal(20, 2)
  /// Snapshot nilai buku sebelum & sesudah (untuk audit & cancel).
  nilaiBukuSebelum Decimal @map("nilai_buku_sebelum") @db.Decimal(20, 2)
  nilaiBukuSesudah Decimal @map("nilai_buku_sesudah") @db.Decimal(20, 2)
  akumulasiSesudah Decimal @map("akumulasi_sesudah") @db.Decimal(20, 2)

  run  DepresiasiRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  aset AsetTetap     @relation(fields: [asetId], references: [id], onDelete: Restrict)

  @@unique([runId, asetId])
  @@index([tenantId, asetId])
  @@map("depresiasi_lines")
}

// ===============================================================
// PAJAK (Fase 7) — Karyawan, Payroll PPh 21, Bukti Potong
// ===============================================================

model Karyawan {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  cabangId          String?       @map("cabang_id") @db.Uuid
  kode              String // KAR-001
  nip               String? // nomor induk pegawai internal
  nik               String // NIK 16 digit
  nama              String
  email             String?
  telp              String?
  alamat            String?
  /// NPWP 15-16 digit (kalau punya). Tanpa NPWP kena surcharge 20% di PPh 21.
  npwp              String?
  ptkpStatus        PtkpStatus
  jenisKaryawan     JenisKaryawan @default(PEGAWAI_TETAP) @map("jenis_karyawan")
  jabatan           String?
  tanggalMasuk      DateTime      @map("tanggal_masuk") @db.Date
  tanggalKeluar     DateTime?     @map("tanggal_keluar") @db.Date
  /// Gaji pokok bulanan default (boleh di-override per PayrollLine).
  gajiPokok         Decimal       @map("gaji_pokok") @db.Decimal(20, 2)
  /// Tunjangan tetap (transport, makan, posisi) — default monthly.
  tunjanganTetap    Decimal       @default(0) @map("tunjangan_tetap") @db.Decimal(20, 2)
  /// Iuran BPJS yang ditanggung KARYAWAN (BPJS Kes 1%, BPJS TK 2% biasa) — di-deduct dari take-home.
  iuranBpjsKaryawan Decimal       @default(0) @map("iuran_bpjs_karyawan") @db.Decimal(20, 2)
  isActive          Boolean       @default(true) @map("is_active")
  catatan           String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang?       @relation(fields: [cabangId], references: [id], onDelete: SetNull)
  payrollLines PayrollLine[]

  @@unique([tenantId, kode])
  @@index([tenantId, isActive])
  @@map("karyawan")
}

/// Run payroll bulanan — 1 per (tenant, periode YYYY-MM) per cabang.
model PayrollRun {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  cabangId       String        @map("cabang_id") @db.Uuid
  fiscalPeriodId String        @map("fiscal_period_id") @db.Uuid
  /// "YYYY-MM"
  periode        String
  /// PR-2026-05-001
  nomor          String?
  tanggal        DateTime      @db.Date
  status         InvoiceStatus @default(DRAFT)

  totalGajiPokok Decimal @default(0) @map("total_gaji_pokok") @db.Decimal(20, 2)
  totalTunjangan Decimal @default(0) @map("total_tunjangan") @db.Decimal(20, 2)
  totalIuranBpjs Decimal @default(0) @map("total_iuran_bpjs") @db.Decimal(20, 2)
  totalPph21     Decimal @default(0) @map("total_pph21") @db.Decimal(20, 2)
  totalTakeHome  Decimal @default(0) @map("total_take_home") @db.Decimal(20, 2)

  /// Akun kas/bank tempat take-home dikeluarkan.
  akunKasBankId String @map("akun_kas_bank_id") @db.Uuid

  journalId              String?   @unique @map("journal_id") @db.Uuid
  postedAt               DateTime? @map("posted_at")
  postedById             String?   @map("posted_by_id") @db.Uuid
  /// Step-up audit: ID user yang meminta posting saat dijalankan dengan
  /// approval kredensial (mis. KASIR meminta AKUNTAN approve). Null untuk
  /// posting langsung. postedById tetap = approver.
  postedRequestedById    String?   @map("posted_requested_by_id") @db.Uuid
  cancelledAt            DateTime? @map("cancelled_at")
  cancelledById          String?   @map("cancelled_by_id") @db.Uuid
  /// Step-up audit: ID requester saat cancel dieksekusi dengan approval kredensial.
  cancelledRequestedById String?   @map("cancelled_requested_by_id") @db.Uuid
  createdById            String?   @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang        @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  lines        PayrollLine[]

  @@unique([tenantId, cabangId, periode])
  @@unique([tenantId, nomor])
  @@index([tenantId, status])
  @@map("payroll_runs")
}

model PayrollLine {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  runId              String       @map("run_id") @db.Uuid
  karyawanId         String       @map("karyawan_id") @db.Uuid
  no                 Int
  /// Snapshot identitas (tahan kalau karyawan rename / NPWP berubah).
  namaSnapshot       String       @map("nama_snapshot")
  npwpSnapshot       String?      @map("npwp_snapshot")
  ptkpStatusSnapshot PtkpStatus   @map("ptkp_status_snapshot")
  ptkpKategori       PtkpKategori @map("ptkp_kategori")

  gajiPokok Decimal @map("gaji_pokok") @db.Decimal(20, 2)
  tunjangan Decimal @default(0) @db.Decimal(20, 2)
  /// Bruto = gajiPokok + tunjangan
  bruto     Decimal @db.Decimal(20, 2)

  /// Tarif TER yang dipakai (%) — disnapshot untuk audit.
  tarifTerPersen Decimal @map("tarif_ter_persen") @db.Decimal(7, 4)
  /// PPh 21 yang dipotong (bruto × tarif TER, +20% kalau tanpa NPWP).
  pph21          Decimal @default(0) @db.Decimal(20, 2)
  iuranBpjs      Decimal @default(0) @map("iuran_bpjs") @db.Decimal(20, 2)
  potonganLain   Decimal @default(0) @map("potongan_lain") @db.Decimal(20, 2)
  /// Take-home = bruto - pph21 - iuranBpjs - potonganLain.
  takeHome       Decimal @map("take_home") @db.Decimal(20, 2)

  catatan String?

  run      PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  karyawan Karyawan   @relation(fields: [karyawanId], references: [id], onDelete: Restrict)

  @@unique([runId, karyawanId])
  @@index([tenantId, karyawanId])
  @@map("payroll_lines")
}

/// Bukti Potong universal (PPh 21 / 23 / 4(2) / dll).
/// Untuk Phase 7: auto-generate dari PurchaseInvoice (PPh 23) dan PayrollLine (PPh 21).
/// Jurnal sudah ter-post di sumbernya — bukti potong di sini cuma untuk pencatatan & rekap SPT Masa.
model BuktiPotong {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  cabangId       String            @map("cabang_id") @db.Uuid
  fiscalPeriodId String            @map("fiscal_period_id") @db.Uuid
  jenisPph       JenisPph          @map("jenis_pph")
  /// Format e-Bupot Unifikasi: pf-YYMMNNNN atau ph-YYMMNNNN.
  nomor          String?
  tanggal        DateTime          @db.Date
  status         BuktiPotongStatus @default(DRAFT)

  /// Pihak yang dipotong.
  pihakNama   String  @map("pihak_nama")
  pihakNpwp   String? @map("pihak_npwp")
  pihakNik    String? @map("pihak_nik")
  pihakAlamat String? @map("pihak_alamat")

  dpp         Decimal @db.Decimal(20, 2)
  /// Tarif persen yang dipakai (mis. 2 untuk PPh 23 jasa, atau hasil TER untuk PPh 21).
  tarifPersen Decimal @map("tarif_persen") @db.Decimal(7, 4)
  pph         Decimal @db.Decimal(20, 2)

  /// Telusur balik: 'PURCHASE_INVOICE_LINE', 'PAYROLL_LINE', 'MANUAL'.
  sumberType String? @map("sumber_type")
  sumberId   String? @map("sumber_id")
  catatan    String?

  /// XML draft (untuk fase 9 Coretax integration).
  xmlDraft String? @map("xml_draft")

  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cabang       Cabang       @relation(fields: [cabangId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)

  @@unique([tenantId, nomor])
  @@index([tenantId, jenisPph, status])
  @@index([sumberType, sumberId])
  @@map("bukti_potong")
}

// ===============================================================
// AUDIT LOG
// ===============================================================

model AuditLog {
  id        BigInt      @id @default(autoincrement())
  tenantId  String?     @map("tenant_id") @db.Uuid
  userId    String?     @map("user_id") @db.Uuid
  action    AuditAction
  entity    String
  entityId  String?     @map("entity_id")
  before    Json?
  after     Json?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

/// Project = wadah budgeting + reporting per-project.
/// Transaksi (journal_lines) opsional attach ke project via projectId.
model Project {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  /// Kode unik per tenant, mis. PRJ-001, RENO-KANTOR, dll.
  kode           String
  nama           String
  deskripsi      String?
  tanggalMulai   DateTime      @map("tanggal_mulai") @db.Date
  tanggalSelesai DateTime?     @map("tanggal_selesai") @db.Date
  status         ProjectStatus @default(AKTIF)
  /// Budget total tingkat project (opsional). Detail per akun × bulan ada di Budget.
  budgetTotal    Decimal?      @map("budget_total") @db.Decimal(20, 2)
  catatan        String?
  /// Klasifikasi jenis industri klien project (mis. Automotive utk project di Toyota).
  industriId     String?       @map("industri_id") @db.Uuid

  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  industri             Industri?             @relation(fields: [industriId], references: [id], onDelete: SetNull)
  members              ProjectMember[]
  budgets              Budget[]
  journalLines         JournalLine[]
  salesInvoiceLines    SalesInvoiceLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
  cashBankEntryLines   CashBankEntryLine[]

  @@unique([tenantId, kode])
  @@index([tenantId, status])
  @@index([industriId])
  @@map("projects")
}

/// Master jenis/klasifikasi industri klien project (mis. Automotive, FMCG,
/// Perbankan). Dipakai untuk mengelompokkan & memfilter laporan per industri.
model Industri {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  kode      String
  nama      String
  isAktif   Boolean  @default(true) @map("is_aktif")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([tenantId, kode])
  @@map("industri")
}

/// Membership user pada project — kontrol siapa boleh input/approve.
model ProjectMember {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

/// Budget per (Project, Akun, Periode bulanan YYYY-MM).
/// Enforcement di posting service: sebelum POST, cek sum posted amount
/// untuk (projectId, accountId, periode) + amount txn ≤ budget.amount.
model Budget {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  projectId String  @map("project_id") @db.Uuid
  accountId String  @map("account_id") @db.Uuid
  /// Format "YYYY-MM"
  periode   String
  amount    Decimal @db.Decimal(20, 2)
  /// true = tolak posting kalau over; false = izinkan tapi ada peringatan.
  hardBlock Boolean @default(true) @map("hard_block")
  catatan   String?

  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([projectId, accountId, periode])
  @@index([tenantId, periode])
  @@map("budgets")
}
