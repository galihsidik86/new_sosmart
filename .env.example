# Postgres — superuser untuk migrasi/seed
POSTGRES_USER=lentera
POSTGRES_PASSWORD=lentera_dev_pwd
POSTGRES_DB=lentera
POSTGRES_PORT=5432

# Aplikasi pakai user terpisah (non-superuser) supaya RLS berlaku
APP_DB_USER=lentera_app
APP_DB_PASSWORD=lentera_app_pwd

# Connection strings
DATABASE_URL="postgresql://lentera:lentera_dev_pwd@localhost:5432/lentera?schema=public"
APP_DATABASE_URL="postgresql://lentera_app:lentera_app_pwd@localhost:5432/lentera?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_URL=http://localhost:4000

# JWT
JWT_ACCESS_SECRET=ganti-di-produksi-access
JWT_REFRESH_SECRET=ganti-di-produksi-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
